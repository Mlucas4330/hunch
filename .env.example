DATABASE_URL=postgres://postgres:postgres@localhost:5432/hunch

# docker compose: Postgres creds + db name. The `app` service derives its own DATABASE_URL from these
# (host `db`), so keep DATABASE_URL above pointed at localhost for host-side `npm run dev`/`db:push`,
# and make sure the db name here matches the one in DATABASE_URL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hunch

AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Admin credentials login (handy for local dev + the Playwright e2e suite).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Used for hypothesis generation AND competitor web-search research.
ANTHROPIC_API_KEY=

# Test-only: when set to 1, POST /api/analyses skips scraping + Claude and returns a
# deterministic fixture. Used by the Playwright e2e suite; leave unset in normal dev.
E2E_FIXTURES=
