DATABASE_URL=postgres://postgres:postgres@localhost:5432/hunch

AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public base URL used to build the embeddable tracking snippet (<script src="APP_URL/embed.js">).
# Safe to expose to the browser. Falls back to window.location.origin when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public base URL of the outreach report surface (e.g. https://reports.hunch.app). Used to build the
# shareable report link (REPORT_URL/r/<embedKey>) sent to prospects. Falls back to NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_REPORT_URL=http://localhost:3000

# Read/write token for Vercel Blob -- stores generated variant-preview screenshots. Server only.
BLOB_READ_WRITE_TOKEN=

# Shared secret for the daily Vercel Cron that auto-finalizes experiments past their end date.
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`. Generate any random string.
CRON_SECRET=

ADMIN_EMAIL=
ADMIN_PASSWORD=

# Used for hypothesis generation AND competitor web-search research.
ANTHROPIC_API_KEY=

# Test-only: when set to 1, POST /api/analyses skips scraping + Claude and returns a
# deterministic fixture. Used by the Playwright e2e suite; leave unset in normal dev.
E2E_FIXTURES=

# Secret key -- server only, never sent to the browser. Restricted key (rk_) preferred over sk_.
STRIPE_SECRET_KEY=
# Publishable key (pk_...) -- safe to expose to the browser; used by embedded checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret printed by `stripe listen --forward-to localhost:3000/api/billing/webhook`.
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (price_...) for the solo/team Products in the Stripe Dashboard.
STRIPE_PRICE_SOLO=
STRIPE_PRICE_TEAM=
